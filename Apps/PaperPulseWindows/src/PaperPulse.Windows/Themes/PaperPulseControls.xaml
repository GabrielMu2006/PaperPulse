<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PaperPulseGlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassFillBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassStrokeBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource OnePixelThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource SurfaceCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource PanelPadding}" />
    </Style>

    <Style x:Key="PaperPulsePaperSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PaperSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="#33FFFFFF" />
        <Setter Property="BorderThickness" Value="{StaticResource OnePixelThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource SurfaceCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>

    <Style x:Key="PaperPulseIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource CompactIconButtonSize}" />
        <Setter Property="Height" Value="{StaticResource CompactIconButtonSize}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{StaticResource GlassFillBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassStrokeBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource OnePixelThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource InputCornerRadius}" />
        <Setter Property="Foreground" Value="{StaticResource ShellTextBrush}" />
    </Style>

    <Style x:Key="PaperPulseProminentButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Background" Value="{StaticResource PulseAccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PulseMagentaBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource OnePixelThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource InputCornerRadius}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="PaperPulseDestructiveButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Background" Value="#33F01A1F" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource OnePixelThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource InputCornerRadius}" />
        <Setter Property="Foreground" Value="{StaticResource ShellTextBrush}" />
    </Style>

    <Style x:Key="PaperPulseInputStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#1AFFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassStrokeBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource OnePixelThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource InputCornerRadius}" />
        <Setter Property="Foreground" Value="{StaticResource ShellTextBrush}" />
        <Setter Property="PlaceholderForeground" Value="{StaticResource ShellSecondaryTextBrush}" />
        <Setter Property="SelectionHighlightColor" Value="#806B2BEB" />
    </Style>

    <Style x:Key="PaperPulseListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ShellTextBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="PaperPulseMetadataPillStyle" TargetType="Border">
        <Setter Property="Background" Value="#22F01A1F" />
        <Setter Property="BorderBrush" Value="#33F01A1F" />
        <Setter Property="BorderThickness" Value="{StaticResource OnePixelThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
</ResourceDictionary>
