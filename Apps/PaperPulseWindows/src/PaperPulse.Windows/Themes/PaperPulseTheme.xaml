<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="ControlFocusVisualPrimaryBrush" Color="#EB1FA3" />
            <SolidColorBrush x:Key="ControlFocusVisualSecondaryBrush" Color="#05030F" />
            <SolidColorBrush x:Key="ButtonBackground" Color="#13FFFFFF" />
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1FFFFFFF" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#33FFFFFF" />
            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#29FFFFFF" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#4DFFFFFF" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#EB1FA3" />
            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="ButtonForeground" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#7A7281" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#33EB1FA3" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#47EB1FA3" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#5CEB1FA3" />
            <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ListViewItemForegroundSelectedPointerOver" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ListViewItemForegroundSelectedPressed" Color="#FFF9FC" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#EB1FA3" />
            <SolidColorBrush x:Key="TextControlBackground" Color="#171923" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#202332" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#252035" />
            <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#0CFFFFFF" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="#29FFFFFF" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#4DFFFFFF" />
            <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="TextControlForeground" Color="#FFF9FC" />
            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#FFF9FC" />
            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#FFF9FC" />
            <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="#7A7281" />
            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#C7C0CB" />
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#C7C0CB" />
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#FFF9FC" />
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundDisabled" Color="#7A7281" />
            <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#171923" />
            <SolidColorBrush x:Key="ComboBoxDropDownForeground" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="#4DFFFFFF" />
            <SolidColorBrush x:Key="ComboBoxItemBackground" Color="#00171923" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#1FFFFFFF" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundPressed" Color="#332D7FF9" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#263AAFEA" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedUnfocused" Color="#1C3AAFEA" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPressed" Color="#403AAFEA" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="#333AAFEA" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundDisabled" Color="#0CFFFFFF" />
            <SolidColorBrush x:Key="ComboBoxItemBorderBrush" Color="#00000000" />
            <SolidColorBrush x:Key="ComboBoxItemBorderBrushPointerOver" Color="#00000000" />
            <SolidColorBrush x:Key="ComboBoxItemBorderBrushPressed" Color="#00000000" />
            <SolidColorBrush x:Key="ComboBoxItemBorderBrushSelected" Color="#3A3AAFEA" />
            <SolidColorBrush x:Key="ComboBoxItemBorderBrushSelectedUnfocused" Color="#2A3AAFEA" />
            <SolidColorBrush x:Key="ComboBoxItemBorderBrushSelectedPressed" Color="#4A3AAFEA" />
            <SolidColorBrush x:Key="ComboBoxItemBorderBrushSelectedPointerOver" Color="#4A3AAFEA" />
            <SolidColorBrush x:Key="ComboBoxItemBorderBrushDisabled" Color="#00000000" />
            <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundPressed" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedUnfocused" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPressed" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="#FFF9FC" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedDisabled" Color="#7A7281" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundDisabled" Color="#7A7281" />
            <CornerRadius x:Key="OverlayCornerRadius">8</CornerRadius>
            <Thickness x:Key="ComboBoxDropdownContentMargin">4</Thickness>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Color x:Key="MidnightColor">#05030F</Color>
    <Color x:Key="DeepBlueColor">#080D29</Color>
    <Color x:Key="DeepPurpleColor">#290538</Color>
    <Color x:Key="PulseRedColor">#F01A1F</Color>
    <Color x:Key="PulseMagentaColor">#EB1FA3</Color>
    <Color x:Key="PulsePurpleColor">#6B2BEB</Color>
    <Color x:Key="WarmGoldColor">#FFA11F</Color>
    <Color x:Key="PaperColor">#FFF7E8</Color>
    <Color x:Key="PaperSoftColor">#FFEEDA</Color>
    <Color x:Key="PaperInkColor">#1F1A21</Color>
    <Color x:Key="PaperSecondaryColor">#5C4F5C</Color>

    <SolidColorBrush x:Key="MidnightBrush" Color="{StaticResource MidnightColor}" />
    <SolidColorBrush x:Key="DeepBlueBrush" Color="{StaticResource DeepBlueColor}" />
    <SolidColorBrush x:Key="DeepPurpleBrush" Color="{StaticResource DeepPurpleColor}" />
    <SolidColorBrush x:Key="PulseRedBrush" Color="{StaticResource PulseRedColor}" />
    <SolidColorBrush x:Key="PulseMagentaBrush" Color="{StaticResource PulseMagentaColor}" />
    <SolidColorBrush x:Key="PulsePurpleBrush" Color="{StaticResource PulsePurpleColor}" />
    <SolidColorBrush x:Key="WarmGoldBrush" Color="{StaticResource WarmGoldColor}" />
    <SolidColorBrush x:Key="PaperInkBrush" Color="{StaticResource PaperInkColor}" />
    <SolidColorBrush x:Key="PaperSecondaryBrush" Color="{StaticResource PaperSecondaryColor}" />
    <SolidColorBrush x:Key="GlassFillBrush" Color="#13FFFFFF" />
    <SolidColorBrush x:Key="GlassFillHoverBrush" Color="#1FFFFFFF" />
    <SolidColorBrush x:Key="GlassStrokeBrush" Color="#29FFFFFF" />
    <SolidColorBrush x:Key="GlassStrokeStrongBrush" Color="#4DFFFFFF" />
    <SolidColorBrush x:Key="ShellTextBrush" Color="#FFF9FC" />
    <SolidColorBrush x:Key="ShellSecondaryTextBrush" Color="#C7C0CB" />
    <SolidColorBrush x:Key="ShellDisabledTextBrush" Color="#7A7281" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FF6B72" />
    <SolidColorBrush x:Key="InputSurfaceBrush" Color="#171923" />
    <SolidColorBrush x:Key="InputSurfacePointerOverBrush" Color="#202332" />
    <SolidColorBrush x:Key="InputSurfaceFocusedBrush" Color="#252035" />
    <SolidColorBrush x:Key="InputBorderFocusedBrush" Color="#EB1FA3" />
    <SolidColorBrush x:Key="InputDisabledBrush" Color="#0CFFFFFF" />

    <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#05030F" />
        <GradientStop Offset="0.32" Color="#080D29" />
        <GradientStop Offset="0.66" Color="#290538" />
        <GradientStop Offset="1" Color="#14051F" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PulseAccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#F01A1F" />
        <GradientStop Offset="0.52" Color="#EB1FA3" />
        <GradientStop Offset="1" Color="#6B2BEB" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PaperSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#FFF7E8" />
        <GradientStop Offset="0.58" Color="#FFFDFC" />
        <GradientStop Offset="1" Color="#FFEEDA" />
    </LinearGradientBrush>

    <CornerRadius x:Key="SmallCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="InputCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="SurfaceCornerRadius">10</CornerRadius>
    <Thickness x:Key="OnePixelThickness">1</Thickness>
    <Thickness x:Key="PanelPadding">12</Thickness>
    <Thickness x:Key="CardPadding">18</Thickness>
    <x:Double x:Key="CompactIconButtonSize">40</x:Double>
    <x:Double x:Key="SectionSpacing">14</x:Double>
</ResourceDictionary>
