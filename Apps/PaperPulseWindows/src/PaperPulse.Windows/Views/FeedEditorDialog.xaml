<ContentDialog
    x:Class="PaperPulse.Windows.Views.FeedEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="FeedEditorDialog"
    CloseButtonText="Cancel"
    CloseButtonStyle="{StaticResource PaperPulseQuietButtonStyle}"
    DefaultButton="Primary"
    PrimaryButtonClick="Save_Click"
    PrimaryButtonStyle="{StaticResource PaperPulseProminentButtonStyle}"
    PrimaryButtonText="Save subscription"
    HorizontalContentAlignment="Center"
    Style="{StaticResource PaperPulseDialogStyle}">
    <ScrollViewer Width="668" MaxHeight="620" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Width="620" Margin="24" Spacing="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Width="38"
                    Height="38"
                    Background="{StaticResource PulseAccentBrush}"
                    CornerRadius="{StaticResource SmallCornerRadius}">
                    <SymbolIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Symbol="Edit" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="DialogTitleText" Foreground="{StaticResource ShellTextBrush}" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock x:Uid="FeedEditorDescription" Foreground="{StaticResource ShellSecondaryTextBrush}" Text="Configure sources and filters for this manual paper push." TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Style="{StaticResource PaperPulseFormSectionStyle}">
                <StackPanel Spacing="8">
                <TextBlock x:Uid="FeedEditorName" Text="Name" FontWeight="SemiBold" />
                <TextBox x:Name="NameBox" x:Uid="FeedEditorNameBox" PlaceholderText="Subscription name" Style="{StaticResource PaperPulseInputStyle}" />
                <TextBlock x:Uid="FeedEditorCategories" Text="arXiv categories" FontWeight="SemiBold" />
                <TextBox x:Name="CategoriesBox" x:Uid="FeedEditorCategoriesBox" PlaceholderText="cs.AI, cs.CL" Style="{StaticResource PaperPulseInputStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PaperPulseFormSectionStyle}">
                <StackPanel Spacing="8">
                <TextBlock x:Uid="FeedEditorKeywords" Text="Keywords (any match)" FontWeight="SemiBold" />
                <TextBox x:Name="KeywordsBox" x:Uid="FeedEditorKeywordsBox" PlaceholderText="agent, retrieval" Style="{StaticResource PaperPulseInputStyle}" />
                <TextBlock x:Uid="FeedEditorExcludedKeywords" Text="Excluded keywords" FontWeight="SemiBold" />
                <TextBox x:Name="ExcludedKeywordsBox" x:Uid="FeedEditorExcludedKeywordsBox" PlaceholderText="survey, editorial" Style="{StaticResource PaperPulseInputStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PaperPulseFormSectionStyle}">
                <StackPanel Spacing="8">
                <TextBlock x:Uid="FeedEditorAuthority" Text="Authority filters" FontWeight="SemiBold" />
                <TextBox x:Name="InstitutionsBox" x:Uid="FeedEditorInstitutionsBox" PlaceholderText="Required institutions, separated by commas" Style="{StaticResource PaperPulseInputStyle}" />
                <TextBox x:Name="VenuesBox" x:Uid="FeedEditorVenuesBox" PlaceholderText="Required venues, separated by commas" Style="{StaticResource PaperPulseInputStyle}" />
                <TextBlock
                    x:Uid="FeedEditorAuthorityHint"
                    Foreground="{StaticResource ShellSecondaryTextBrush}"
                    Text="Leave institutions and venues empty to allow any, while authority evaluation still applies."
                    TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PaperPulseFormSectionStyle}">
                <StackPanel Spacing="8">
                <TextBlock x:Uid="FeedEditorSources" Text="Academic sources" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <CheckBox x:Name="ArxivCheckBox" Content="arXiv" Style="{StaticResource PaperPulseCheckBoxStyle}" />
                    <CheckBox x:Name="OpenAlexCheckBox" Content="OpenAlex" Style="{StaticResource PaperPulseCheckBoxStyle}" />
                    <CheckBox x:Name="CrossrefCheckBox" Content="Crossref" Style="{StaticResource PaperPulseCheckBoxStyle}" />
                </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PaperPulseFormSectionStyle}">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="FeedEditorLimit" Text="Papers per push" FontWeight="SemiBold" />
                        <TextBox
                            x:Name="DailyLimitBox"
                            BeforeTextChanging="NumericBox_BeforeTextChanging"
                            PlaceholderText="8"
                            Style="{StaticResource PaperPulseInputStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock x:Uid="FeedEditorLookback" Text="Lookback days" FontWeight="SemiBold" />
                        <TextBox
                            x:Name="LookbackDaysBox"
                            BeforeTextChanging="NumericBox_BeforeTextChanging"
                            PlaceholderText="7"
                            Style="{StaticResource PaperPulseInputStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock
                x:Name="ValidationText"
                Foreground="{StaticResource DangerBrush}"
                TextWrapping="Wrap"
                Visibility="Collapsed" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
