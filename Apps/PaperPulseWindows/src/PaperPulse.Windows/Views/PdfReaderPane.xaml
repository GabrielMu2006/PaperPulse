<UserControl
    x:Class="PaperPulse.Windows.Views.PdfReaderPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">
    <Grid Background="{StaticResource MidnightBrush}">
            <Border
                x:Name="StateSurface"
                MaxWidth="320"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource PaperPulseGlassPanelStyle}">
                <StackPanel Spacing="8">
                    <SymbolIcon
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource PulseMagentaBrush}"
                        Symbol="Document" />
                    <TextBlock
                        x:Name="StateTitle"
                        Foreground="{StaticResource ShellTextBrush}"
                        TextAlignment="Center"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="StateMessage"
                        Foreground="{StaticResource ShellSecondaryTextBrush}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <WebView2
                x:Name="PdfViewer"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Visibility="Collapsed" />
    </Grid>
</UserControl>
