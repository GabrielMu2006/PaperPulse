<UserControl
    x:Class="PaperPulse.Windows.Views.LibrarySidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PaperPulse.Windows.Views"
    x:Name="Root">
    <UserControl.Resources>
        <views:FeedSummaryConverter x:Key="FeedSummaryConverter" />
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14">
            <Grid ColumnSpacing="10">
                <Border
                    Width="34"
                    Height="34"
                    Background="{StaticResource PulseAccentBrush}"
                    CornerRadius="{StaticResource SmallCornerRadius}">
                    <SymbolIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Symbol="Document" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock
                        Foreground="{StaticResource ShellTextBrush}"
                        Text="PaperPulse"
                        FontSize="20"
                        FontWeight="SemiBold" />
                    <TextBlock
                        Foreground="{StaticResource ShellSecondaryTextBrush}"
                        MaxLines="1"
                        Text="{Binding Status}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>

            <TextBox
                PlaceholderText="Search papers"
                Style="{StaticResource PaperPulseInputStyle}"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <Grid ColumnSpacing="6">
                <Button
                    AutomationProperties.Name="Show all papers"
                    Click="AllPapers_Click"
                    Content="All papers"
                    HorizontalAlignment="Stretch" />
                <ToggleButton
                    Grid.Column="1"
                    AutomationProperties.Name="Show favorite papers"
                    Content="Favorites"
                    IsChecked="{Binding FavoritesOnly, Mode=TwoWay}" />
            </Grid>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    AutomationProperties.Name="New subscription"
                    Click="AddFeed_Click"
                    HorizontalAlignment="Stretch"
                    ToolTipService.ToolTip="New subscription">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Add" />
                        <TextBlock Text="New subscription" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="1"
                    AutomationProperties.Name="Open settings"
                    Click="Settings_Click"
                    ToolTipService.ToolTip="Open settings">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Setting" />
                        <TextBlock Text="Settings" />
                    </StackPanel>
                </Button>
            </Grid>

            <TextBlock Foreground="{StaticResource ShellSecondaryTextBrush}" Text="Feeds" FontWeight="SemiBold" />

            <ListView
                Background="Transparent"
                BorderThickness="0"
                Foreground="{StaticResource ShellTextBrush}"
                ItemContainerStyle="{StaticResource PaperPulseListViewItemStyle}"
                ItemsSource="{Binding Feeds}"
                SelectedItem="{Binding SelectedFeed, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="6" ColumnSpacing="8">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Click="EditFeed_Click" Tag="{Binding}" Text="Edit subscription" />
                                    <MenuFlyoutItem Click="DeleteFeed_Click" Tag="{Binding}" Text="Delete subscription" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Width="22"
                                Height="22"
                                Background="{StaticResource PulseAccentBrush}"
                                CornerRadius="{StaticResource SmallCornerRadius}">
                                <SymbolIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Symbol="Folder" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Foreground="{StaticResource ShellTextBrush}"
                                    MaxLines="1"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Foreground="{StaticResource ShellSecondaryTextBrush}"
                                    MaxLines="1"
                                    Text="{Binding Converter={StaticResource FeedSummaryConverter}}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button
                                Grid.Column="2"
                                AutomationProperties.Name="Push this subscription"
                                Click="FeedPush_Click"
                                Style="{StaticResource PaperPulseIconButtonStyle}"
                                ToolTipService.ToolTip="Push this subscription">
                                <SymbolIcon Symbol="Send" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid>
                <TextBlock
                    Foreground="{StaticResource ShellTextBrush}"
                    Text="Library"
                    FontWeight="SemiBold" />
                <TextBlock
                    HorizontalAlignment="Right"
                    Foreground="{StaticResource ShellSecondaryTextBrush}"
                    Text="{Binding Papers.Count}" />
            </Grid>

            <ItemsControl ItemsSource="{Binding LibraryGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander
                            Foreground="{StaticResource ShellTextBrush}"
                            IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                            <Expander.Header>
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <SymbolIcon
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource PulseMagentaBrush}"
                                        Symbol="Folder" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource ShellTextBrush}"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="2" Style="{StaticResource PaperPulseMetadataPillStyle}">
                                        <TextBlock
                                            Foreground="{StaticResource ShellTextBrush}"
                                            Text="{Binding Papers.Count}" />
                                    </Border>
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Margin="8,2"
                                    Foreground="{StaticResource ShellSecondaryTextBrush}"
                                    Opacity="{Binding EmptyStateOpacity}"
                                    Text="No papers pushed yet." />
                                <ListView
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource ShellTextBrush}"
                                    ItemContainerStyle="{StaticResource PaperPulseListViewItemStyle}"
                                    ItemsSource="{Binding Papers}"
                                    SelectionChanged="PaperList_SelectionChanged">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,5" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="20" />
                                                </Grid.ColumnDefinitions>
                                                <Border
                                                    Width="3"
                                                    Background="{StaticResource PulseAccentBrush}"
                                                    CornerRadius="{StaticResource SmallCornerRadius}"
                                                    Opacity="{Binding SelectionAccentOpacity}" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock
                                                        Foreground="{StaticResource ShellTextBrush}"
                                                        MaxLines="2"
                                                        Text="{Binding Title}"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="Wrap"
                                                        FontWeight="SemiBold" />
                                                    <Grid>
                                                        <TextBlock
                                                            Foreground="{StaticResource ShellSecondaryTextBrush}"
                                                            MaxLines="1"
                                                            Text="{Binding Authors}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            Foreground="{StaticResource ShellSecondaryTextBrush}"
                                                            Text="{Binding Date}" />
                                                    </Grid>
                                                    <TextBlock
                                                        Foreground="{StaticResource ShellSecondaryTextBrush}"
                                                        MaxLines="2"
                                                        Text="{Binding Brief}"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                                <SymbolIcon
                                                    Grid.Column="2"
                                                    VerticalAlignment="Top"
                                                    Foreground="{StaticResource WarmGoldBrush}"
                                                    Opacity="{Binding FavoriteOpacity}"
                                                    Symbol="Favorite" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
