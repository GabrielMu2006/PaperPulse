<ContentDialog
    x:Class="PaperPulse.Windows.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CloseButtonText="Cancel"
    PrimaryButtonClick="Save_Click"
    PrimaryButtonText="Save settings"
    Title="Settings">
    <StackPanel Width="520" Spacing="16">
        <TextBlock Text="Language" FontSize="20" FontWeight="SemiBold" />
        <TextBlock Text="Interface language" FontWeight="SemiBold" />
        <ComboBox x:Name="UiLanguageBox" SelectedIndex="0">
            <ComboBoxItem Content="English" Tag="en-US" />
            <ComboBoxItem Content="Chinese" Tag="zh-CN" />
        </ComboBox>
        <TextBlock Text="Brief language" FontWeight="SemiBold" />
        <ComboBox x:Name="SummaryLanguageBox" SelectedIndex="0">
            <ComboBoxItem Content="English" Tag="en-US" />
            <ComboBoxItem Content="Chinese" Tag="zh-CN" />
        </ComboBox>
        <TextBlock Text="Keyword library" FontWeight="SemiBold" />
        <TextBox x:Name="KeywordLibraryBox" AcceptsReturn="True" MinHeight="84" PlaceholderText="agent, retrieval, multimodal" TextWrapping="Wrap" />
        <TextBlock Text="Storage" FontSize="20" FontWeight="SemiBold" />
        <Button Click="ClearUnclassified_Click" HorizontalAlignment="Left" Style="{StaticResource PaperPulseDestructiveButtonStyle}">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <SymbolIcon Symbol="Delete" />
                <TextBlock Text="Clear unclassified papers" />
            </StackPanel>
        </Button>
    </StackPanel>
</ContentDialog>
