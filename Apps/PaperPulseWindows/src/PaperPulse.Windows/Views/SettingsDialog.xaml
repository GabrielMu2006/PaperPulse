<ContentDialog
    x:Class="PaperPulse.Windows.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="SettingsDialog"
    CloseButtonText="Cancel"
    CloseButtonStyle="{StaticResource PaperPulseQuietButtonStyle}"
    PrimaryButtonClick="Save_Click"
    PrimaryButtonText="Save settings"
    PrimaryButtonStyle="{StaticResource PaperPulseProminentButtonStyle}"
    HorizontalContentAlignment="Center"
    Style="{StaticResource PaperPulseDialogStyle}">
    <ScrollViewer
        Width="608"
        MaxHeight="620"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Hidden">
        <ScrollViewer.RenderTransform>
            <TranslateTransform X="-18" />
        </ScrollViewer.RenderTransform>
        <StackPanel Width="560" Margin="24" Spacing="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Width="38"
                    Height="38"
                    Background="{StaticResource PulseAccentBrush}"
                    CornerRadius="{StaticResource SmallCornerRadius}">
                    <SymbolIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Symbol="Setting" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Uid="SettingsDialogHeading" Foreground="{StaticResource ShellTextBrush}" Text="Settings" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock x:Uid="SettingsSaveHint" Foreground="{StaticResource ShellSecondaryTextBrush}" Text="Changes are applied only after Save." TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Style="{StaticResource PaperPulseFormSectionStyle}">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="SettingsLanguageHeading" Text="Language" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Uid="SettingsInterfaceLanguage" Text="Interface language" FontWeight="SemiBold" />
                    <Button x:Name="UiLanguageButton" Style="{StaticResource PaperPulseSelectButtonStyle}">
                        <Button.Flyout>
                            <Flyout Placement="Bottom" FlyoutPresenterStyle="{StaticResource PaperPulseFlyoutPresenterStyle}">
                                <StackPanel Width="180" Spacing="4">
                                    <Button x:Name="UiEnglishOption" x:Uid="SettingsEnglish" Click="UiLanguageOption_Click" Content="English" Style="{StaticResource PaperPulseFlyoutOptionButtonStyle}" Tag="en-US" />
                                    <Button x:Name="UiChineseOption" x:Uid="SettingsChinese" Click="UiLanguageOption_Click" Content="Chinese" Style="{StaticResource PaperPulseFlyoutOptionButtonStyle}" Tag="zh-CN" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="UiLanguageText" VerticalAlignment="Center" />
                            <FontIcon Grid.Column="1" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE0E5;" />
                        </Grid>
                    </Button>
                    <TextBlock x:Uid="SettingsBriefLanguage" Text="Brief language" FontWeight="SemiBold" />
                    <Button x:Name="SummaryLanguageButton" Style="{StaticResource PaperPulseSelectButtonStyle}">
                        <Button.Flyout>
                            <Flyout Placement="Bottom" FlyoutPresenterStyle="{StaticResource PaperPulseFlyoutPresenterStyle}">
                                <StackPanel Width="180" Spacing="4">
                                    <Button x:Name="SummaryEnglishOption" x:Uid="SettingsBriefEnglish" Click="SummaryLanguageOption_Click" Content="English" Style="{StaticResource PaperPulseFlyoutOptionButtonStyle}" Tag="en-US" />
                                    <Button x:Name="SummaryChineseOption" x:Uid="SettingsBriefChinese" Click="SummaryLanguageOption_Click" Content="Chinese" Style="{StaticResource PaperPulseFlyoutOptionButtonStyle}" Tag="zh-CN" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SummaryLanguageText" VerticalAlignment="Center" />
                            <FontIcon Grid.Column="1" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE0E5;" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PaperPulseFormSectionStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Keyword library" FontWeight="SemiBold" />
                    <TextBox x:Name="KeywordLibraryBox" AcceptsReturn="True" MinHeight="84" PlaceholderText="agent, retrieval, multimodal" Style="{StaticResource PaperPulseInputStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PaperPulseFormSectionStyle}">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="SettingsStorageHeading" Text="Storage" FontSize="20" FontWeight="SemiBold" />
                    <Button Click="ClearUnclassified_Click" HorizontalAlignment="Left" Style="{StaticResource PaperPulseDestructiveButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Delete" />
                            <TextBlock x:Uid="SettingsClearUnclassified" Text="Clear unclassified papers" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
