<Window
    x:Class="PaperPulse.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PaperPulse">
    <Grid ColumnSpacing="16" Padding="16">
        <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Grid.ColumnSpan="3" Text="PaperPulse" FontSize="24" FontWeight="SemiBold" />
        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="Subscriptions" FontWeight="SemiBold" />
            <ListView ItemsSource="{Binding Feeds}" SelectedItem="{Binding SelectedFeed, Mode=TwoWay}" DisplayMemberPath="Name" Height="480" />
            <Button Click="Refresh_Click" ToolTipService.ToolTip="Search this subscription"><StackPanel Orientation="Horizontal" Spacing="8"><SymbolIcon Symbol="Send"/><TextBlock Text="Search"/></StackPanel></Button>
        </StackPanel>
        <Grid Grid.Column="1" Grid.Row="1" RowSpacing="10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <TextBox PlaceholderText="Search papers" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ListView Grid.Row="1" ItemsSource="{Binding VisiblePapers}" SelectedItem="{Binding SelectedPaper, Mode=TwoWay}">
                <ListView.ItemTemplate><DataTemplate><StackPanel Spacing="3" Padding="8"><TextBlock Text="{Binding Candidate.Title}" FontWeight="SemiBold" TextWrapping="Wrap"/><TextBlock Text="{Binding Candidate.Authors[0]}" Opacity="0.7"/><TextBlock Text="{Binding Candidate.Summary}" MaxLines="2" TextWrapping="Wrap" Opacity="0.75"/></StackPanel></DataTemplate></ListView.ItemTemplate>
            </ListView>
        </Grid>
        <StackPanel Grid.Column="2" Grid.Row="1" Spacing="12"><TextBlock Text="Details" FontWeight="SemiBold"/><TextBlock Text="{Binding SelectedPaper.Candidate.Title}" FontSize="20" TextWrapping="Wrap"/><TextBlock Text="{Binding SelectedPaper.Candidate.Summary}" TextWrapping="Wrap"/><Button Click="Favorite_Click"><StackPanel Orientation="Horizontal" Spacing="8"><SymbolIcon Symbol="Favorite"/><TextBlock Text="Favorite"/></StackPanel></Button></StackPanel>
        <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Text="{Binding Status}" Opacity="0.75"/>
    </Grid>
</Window>
