<Window
    x:Class="PaperPulse.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root"
    Title="PaperPulse">
    <Grid
        Background="{StaticResource ShellBackgroundBrush}"
        ColumnSpacing="16"
        Padding="16"
        RequestedTheme="Dark">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.ColumnSpan="3"
            Foreground="{StaticResource ShellTextBrush}"
            Text="PaperPulse"
            FontSize="24"
            FontWeight="SemiBold" />

        <Border Grid.Row="1" Style="{StaticResource PaperPulseGlassPanelStyle}">
            <StackPanel Spacing="8">
                <Grid>
                    <TextBlock Foreground="{StaticResource ShellTextBrush}" Text="Subscriptions" FontWeight="SemiBold" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="4">
                        <Button
                            AutomationProperties.Name="New subscription"
                            Click="AddFeed_Click"
                            Style="{StaticResource PaperPulseIconButtonStyle}"
                            ToolTipService.ToolTip="New subscription">
                            <SymbolIcon Symbol="Add" />
                        </Button>
                        <Button
                            AutomationProperties.Name="Edit selected subscription"
                            Click="EditFeed_Click"
                            Style="{StaticResource PaperPulseIconButtonStyle}"
                            ToolTipService.ToolTip="Edit selected subscription">
                            <SymbolIcon Symbol="Edit" />
                        </Button>
                        <Button
                            AutomationProperties.Name="Delete selected subscription"
                            Click="DeleteFeed_Click"
                            Style="{StaticResource PaperPulseIconButtonStyle}"
                            ToolTipService.ToolTip="Delete selected subscription">
                            <SymbolIcon Symbol="Delete" />
                        </Button>
                    </StackPanel>
                </Grid>
                <ListView
                    Background="Transparent"
                    BorderBrush="{StaticResource GlassStrokeBrush}"
                    BorderThickness="{StaticResource OnePixelThickness}"
                    DisplayMemberPath="Name"
                    Foreground="{StaticResource ShellTextBrush}"
                    Height="440"
                    ItemContainerStyle="{StaticResource PaperPulseListViewItemStyle}"
                    ItemsSource="{Binding Feeds}"
                    SelectedItem="{Binding SelectedFeed, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        AutomationProperties.Name="Search selected subscription"
                        Click="Refresh_Click"
                        Style="{StaticResource PaperPulseIconButtonStyle}"
                        ToolTipService.ToolTip="Search selected subscription">
                        <SymbolIcon Symbol="Send" />
                    </Button>
                    <Button
                        AutomationProperties.Name="Show only favorites"
                        Click="FavoritesFilter_Click"
                        Style="{StaticResource PaperPulseIconButtonStyle}"
                        ToolTipService.ToolTip="Show only favorites">
                        <SymbolIcon Symbol="Favorite" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource PaperPulseGlassPanelStyle}">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBox
                    PlaceholderText="Search papers"
                    Style="{StaticResource PaperPulseInputStyle}"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding LibraryGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander
                                    Foreground="{StaticResource ShellTextBrush}"
                                    Header="{Binding Header}"
                                    IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                    <ListView
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{StaticResource ShellTextBrush}"
                                        ItemContainerStyle="{StaticResource PaperPulseListViewItemStyle}"
                                        ItemsSource="{Binding Papers}"
                                        SelectionChanged="PaperList_SelectionChanged">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Padding="8" Spacing="3">
                                                    <TextBlock Foreground="{StaticResource ShellTextBrush}" FontWeight="SemiBold" Text="{Binding Candidate.Title}" TextWrapping="Wrap" />
                                                    <TextBlock Foreground="{StaticResource ShellSecondaryTextBrush}" Text="{Binding Candidate.SourceId}" />
                                                    <TextBlock Foreground="{StaticResource ShellSecondaryTextBrush}" MaxLines="2" Text="{Binding Candidate.Summary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="2" Grid.Row="1" Style="{StaticResource PaperPulseGlassPanelStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Foreground="{StaticResource ShellTextBrush}" Text="Details" FontWeight="SemiBold" />
                    <Button
                        AutomationProperties.Name="Toggle favorite for selected paper"
                        Click="Favorite_Click"
                        HorizontalAlignment="Right"
                        IsEnabled="{Binding HasSelectedPaper}"
                        Style="{StaticResource PaperPulseIconButtonStyle}"
                        ToolTipService.ToolTip="Toggle favorite for selected paper">
                        <SymbolIcon Symbol="Favorite" />
                    </Button>
                </Grid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                    <Button
                        AutomationProperties.Name="Open downloaded PDF"
                        Click="OpenPdf_Click"
                        IsEnabled="{Binding HasSelectedPdf}"
                        Style="{StaticResource PaperPulseIconButtonStyle}"
                        ToolTipService.ToolTip="Open downloaded PDF">
                        <SymbolIcon Symbol="OpenFile" />
                    </Button>
                </StackPanel>
                <ScrollViewer Grid.Row="2">
                    <StackPanel Spacing="12">
                        <TextBlock Foreground="{StaticResource ShellTextBrush}" FontSize="20" Text="{Binding SelectedPaperTitle}" TextWrapping="Wrap" />
                        <TextBlock Foreground="{StaticResource ShellSecondaryTextBrush}" Text="{Binding SelectedPaperSummary}" TextWrapping="Wrap" />
                        <TextBlock x:Name="PdfEmptyState" Foreground="{StaticResource ShellSecondaryTextBrush}" Text="This paper has no local PDF. Push its subscription again to retry." TextWrapping="Wrap" />
                        <WebView2 x:Name="PdfViewer" Height="420" Visibility="Collapsed" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Foreground="{StaticResource ShellSecondaryTextBrush}" Text="{Binding Status}" />
    </Grid>
</Window>
