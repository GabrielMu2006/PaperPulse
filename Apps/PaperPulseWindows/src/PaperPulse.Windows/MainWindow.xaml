<Window
    x:Class="PaperPulse.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root"
    Title="PaperPulse">
    <Grid ColumnSpacing="16" Padding="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.ColumnSpan="3" Text="PaperPulse" FontSize="24" FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Spacing="8">
            <Grid>
                <TextBlock Text="Subscriptions" FontWeight="SemiBold" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="4">
                    <Button Click="AddFeed_Click" ToolTipService.ToolTip="New subscription">
                        <SymbolIcon Symbol="Add" />
                    </Button>
                    <Button Click="EditFeed_Click" ToolTipService.ToolTip="Edit selected subscription">
                        <SymbolIcon Symbol="Edit" />
                    </Button>
                    <Button Click="DeleteFeed_Click" ToolTipService.ToolTip="Delete selected subscription">
                        <SymbolIcon Symbol="Delete" />
                    </Button>
                </StackPanel>
            </Grid>
            <ListView
                Height="440"
                DisplayMemberPath="Name"
                ItemsSource="{Binding Feeds}"
                SelectedItem="{Binding SelectedFeed, Mode=TwoWay}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Click="Refresh_Click" ToolTipService.ToolTip="Search selected subscription">
                    <SymbolIcon Symbol="Send" />
                </Button>
                <Button Click="FavoritesFilter_Click" ToolTipService.ToolTip="Show only favorites">
                    <SymbolIcon Symbol="Favorite" />
                </Button>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Column="1" Grid.Row="1" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBox
                PlaceholderText="Search papers"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding LibraryGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Header="{Binding Header}" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                <ListView ItemsSource="{Binding Papers}" SelectionChanged="PaperList_SelectionChanged">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Padding="8" Spacing="3">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Candidate.Title}" TextWrapping="Wrap" />
                                                <TextBlock Opacity="0.7" Text="{Binding Candidate.SourceId}" />
                                                <TextBlock MaxLines="2" Opacity="0.75" Text="{Binding Candidate.Summary}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="2" Grid.Row="1" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
                <TextBlock Text="Details" FontWeight="SemiBold" />
                <Button
                    Click="Favorite_Click"
                    HorizontalAlignment="Right"
                    IsEnabled="{Binding HasSelectedPaper}"
                    ToolTipService.ToolTip="Toggle favorite for selected paper">
                    <SymbolIcon Symbol="Favorite" />
                </Button>
            </Grid>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                <Button
                    Click="DownloadPdf_Click"
                    IsEnabled="{Binding HasSelectedPaper}"
                    ToolTipService.ToolTip="Download verified open-access PDF">
                    <SymbolIcon Symbol="Download" />
                </Button>
                <Button
                    Click="OpenPdf_Click"
                    IsEnabled="{Binding HasSelectedPdf}"
                    ToolTipService.ToolTip="Open downloaded PDF">
                    <SymbolIcon Symbol="OpenFile" />
                </Button>
            </StackPanel>
            <ScrollViewer Grid.Row="2">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="20" Text="{Binding SelectedPaperTitle}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedPaperSummary}" TextWrapping="Wrap" />
                    <TextBlock x:Name="PdfEmptyState" Opacity="0.7" Text="Download a verified open-access PDF to read it here." TextWrapping="Wrap" />
                    <WebView2 x:Name="PdfViewer" Height="420" Visibility="Collapsed" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Opacity="0.75" Text="{Binding Status}" />
    </Grid>
</Window>
